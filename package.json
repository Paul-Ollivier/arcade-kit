{
  "name": "@domin8/arcade-kit",
  "version": "1.15.2",
  "description": "Shared pixel-art arcade UI for the Domin8 hub and its games — 9-slice buttons, panels, inputs, bitmap fonts, and their sprite assets.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./pixi": {
      "types": "./src/pixi/index.ts",
      "default": "./src/pixi/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "pixi.js": ">=8"
  },
  "peerDependenciesMeta": {
    "pixi.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": ">=18",
    "pixi.js": "^8.19.0",
    "typescript": "^5"
  }
}
